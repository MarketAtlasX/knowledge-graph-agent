# Environment Configuration for Geopolitical Knowledge Graph Intelligence Agent

# Logging Configuration
LOG_LEVEL=INFO
DEBUG=False

# ===== REQUIRED: News APIs =====
# Get free key from https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# GDELT API (free, no key needed for basic access)
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/search/tv

# Financial News APIs
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# ACLED API (free, geopolitical conflicts)
ACLED_BASE_URL=https://api.acleddata.com

# ===== LLM Configuration (Optional) =====
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# ===== Database Configuration (Optional) =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ===== Application Configuration =====
APP_NAME=Geopolitical Knowledge Graph Intelligence Agent
APP_VERSION=2.0.0

# Workflow Configuration
MAX_RETRIES=3
REQUEST_TIMEOUT=30
MAX_ARTICLES_PER_SOURCE=50

# API Rate Limiting
GDELT_RATE_LIMIT=10
NEWSAPI_RATE_LIMIT=100
FINNHUB_RATE_LIMIT=5
